# Copy to .env and fill in real values before running docker compose / deploy.sh.
# This file is consumed by docker-compose.yml at the repo root - it is
# separate from backend/.env and frontend/.env, which are only used for
# local (non-Docker) development.

# --- Domains (DNS must already point A/AAAA records at this server) ---
WEBAPP_DOMAIN=bilimbattle.uz
API_DOMAIN=api.bilimbattle.uz
BOT_USERNAME=bilimbattle_bot
# Used by acme-companion for Let's Encrypt renewal notices.
SSL_EMAIL=you@example.com

# --- Database ---
DB_USER=postgres
DB_PASSWORD=change-this-to-a-strong-password
DB_NAME=bilimbattle

# --- Backend secrets ---
JWT_SECRET=change-this-to-a-long-random-string
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# --- Admin identity ---
# Your own numeric Telegram user id (message @userinfobot to find it). Used
# by three things: scripts/healthcheck-alert.sh (DMs this id on down/
# recovery), the backend's /api/admin/stats gate (403s any other
# telegramId), and the frontend build (shows the in-app "Admin statistikasi"
# row in Settings only to this telegramId - a UX nicety, NOT the real
# security boundary, which is the backend gate above).
ADMIN_TELEGRAM_ID=your-telegram-user-id

# --- Standalone admin dashboard (https://api.bilimbattle.uz/admin/stats) ---
# HTTP Basic Auth password (any username works) for the browser-only
# version of the same dashboard, kept as a fallback if the Mini App itself
# is unreachable. Leave unset to keep it disabled (responds 503).
ADMIN_PASSWORD=change-this-to-a-strong-password
